---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  slideDuration?: number;
}

const { slideDuration = 2500 } = Astro.props;

const slideModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/hero-carousel/*.png',
  { eager: true }
);
const slides = Object.values(slideModules).map(m => m.default);
---

<div
  class="hero-slideshow"
  data-hero-carousel
  data-slide-duration={slideDuration}
>
  {slides.map((slide, i) => (
    <div class={`slide${i === 0 ? ' is-active' : ''}`}>
      <Image
        src={slide}
        alt=""
        widths={[1280, 1920, 2560]}
        sizes="100vw"
        loading={i === 0 ? 'eager' : 'lazy'}
        style="width: 100%; height: 100%; object-fit: cover; display: block;"
      />
    </div>
  ))}
</div>

<style>
  .hero-slideshow {
    position: absolute;
    inset: 0;
  }

  .slide {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .slide.is-active {
    z-index: 1;
  }
</style>

<script>
  function advance(slides: NodeListOf<Element>, current: { value: number }) {
    slides[current.value].classList.remove('is-active');
    current.value = (current.value + 1) % slides.length;
    slides[current.value].classList.add('is-active');
  }

  document.addEventListener('astro:page-load', () => {
    const container = document.querySelector('[data-hero-carousel]');
    if (!container) return;

    const slideDuration = Number((container as HTMLElement).dataset.slideDuration) || 2500;
    const slides = container.querySelectorAll('.slide');
    const current = { value: 0 };

    slides[0]?.classList.add('is-active');

    const id = setInterval(() => advance(slides, current), slideDuration);
    document.addEventListener('astro:before-swap', () => clearInterval(id), { once: true });
  });
</script>
