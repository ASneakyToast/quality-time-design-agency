---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Capabilities from '@/components/global/Capabilities.astro';
import ContactShowcase from '@/components/home/ContactShowcase.astro';
import HeroCarousel from '@/components/home/HeroCarousel.astro';
---

<BaseLayout>
  <!-- Hero Carousel -->
  <section class="hero">
    <HeroCarousel slideDuration={500} />
  </section>

  <!-- Capabilities -->
  <Capabilities />

  <!-- Contact Teaser -->
  <ContactShowcase />
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: var(--hero-height);
    min-height: max(var(--hero-min-height), var(--hero-height));
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 85svh;
    }
  }
</style>

