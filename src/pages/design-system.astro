  .ds-type-sample--5xl    { font-size: var(--text-5xl); }
  .ds-type-sample--4xl    { font-size: var(--text-4xl); }
  .ds-type-sample--3xl    { font-size: var(--text-3xl); }
  .ds-type-sample--2xl    { font-size: var(--text-2xl); }
  .ds-type-sample--xl     { font-size: var(--text-xl); }
  .ds-type-sample--lg     { font-size: var(--text-lg); font-family: var(--font-body); }
  .ds-type-sample--base   { font-size: var(--text-base); font-family: var(--font-body); }
  .ds-type-sample--sm     { font-size: var(--text-sm); font-family: var(--font-body); }
  .ds-type-sample--xs     { font-size: var(--text-xs); font-family: var(--font-body); }

  /* ==========================================================================
     Typography — Heading Hierarchy
     ========================================================================== */
  .ds-heading-demo {
    display: flex;
    flex-direction: column;
    gap: 0;
