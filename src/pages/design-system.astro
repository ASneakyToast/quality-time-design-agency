              <div class="ds-container-row">
                <span class="ds-space-token"><code>{token}</code>{note && <em>{note}</em>}</span>
                <div class="ds-container-bar-wrap">
                  <div class="ds-container-bar" style={`width: min(${value}, 100%);`}></div>
                </div>
                <span class="ds-space-value">{value}</span>
