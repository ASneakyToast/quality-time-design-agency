              <div class="ds-ease-track">
                <div class="ds-ease-ball ds-ease-ball--out"></div>
              </div>
              <span class="ds-token-name">--ease-out</span>
            </div>
            <div class="ds-ease-demo">
              <div class="ds-ease-track">
                <div class="ds-ease-ball ds-ease-ball--in-out"></div>
              </div>
              <span class="ds-token-name">--ease-in-out</span>
            </div>
            <div class="ds-ease-demo">
              <div class="ds-ease-track">
                <div class="ds-ease-ball ds-ease-ball--spring"></div>
              </div>
              <span class="ds-token-name">--ease-spring</span>
            </div>
            <div class="ds-ease-demo">
              <div class="ds-ease-track">
                <div class="ds-ease-ball ds-ease-ball--spring-soft"></div>
              </div>
              <span class="ds-token-name">--ease-spring-soft</span>
            </div>
            <div class="ds-ease-demo">
              <div class="ds-ease-track">
                <div class="ds-ease-ball ds-ease-ball--spring-bounce"></div>
              </div>
              <span class="ds-token-name">--ease-spring-bounce</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======================================================
         GRID
         ====================================================== -->
    <section class="ds-section" id="grid">
      <div class="ds-container">
        <h2 class="ds-section-title">Grid System</h2>
        <p class="ds-section-desc">10-column Collins-style grid with fluid gutters.</p>

        <div class="ds-subsection">
