              <div class="ds-grid-span-label col-span-4">col-span-4</div>
              <div class="ds-grid-span-label col-span-6">col-span-6</div>
            </div>
          </div>

          <div class="ds-table" style="margin-top: var(--space-8);">
            <div class="ds-table-row ds-table-header">
              <span>Token</span><span>Value</span>
            </div>
            <div class="ds-table-row">
              <span><code>--grid-columns</code></span><span>10</span>
            </div>
            <div class="ds-table-row">
              <span><code>--grid-column-gap</code></span><span>clamp(16px, 2vw, 24px)</span>
            </div>
            <div class="ds-table-row">
              <span><code>--grid-gap-sm</code></span><span>clamp(12px, 2vw, 16px)</span>
