---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Design System"
  description="Visual reference for Quality Time's design tokens, typography, color palette, and component patterns."
>
  <div class="ds">

    <!-- ======================================================
         PAGE HEADER
         ====================================================== -->
    <header class="ds-header">
      <div class="ds-container">
        <p class="ds-eyebrow">Internal Reference</p>
        <h1 class="ds-title">Design System</h1>
        <p class="ds-subtitle">
          A living visual reference for Quality Time's tokens, typography, and
          color palette. Use this page to QA branding changes.
        </p>
      </div>
    </header>

    <!-- ======================================================
         TYPOGRAPHY
         ====================================================== -->
    <section class="ds-section" id="typography">
      <div class="ds-container">
        <h2 class="ds-section-title">Typography</h2>

        <!-- Font Families -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Font Families</h3>
          <div class="ds-font-grid">
            <div class="ds-font-card">
              <div class="ds-font-specimen ds-font-specimen--display">
                Aa Bb Cc
              </div>
              <div class="ds-font-meta">
                <span class="ds-token-name">--font-display</span>
                <span class="ds-font-name">Host Grotesk</span>
                <span class="ds-font-fallback">-apple-system, BlinkMacSystemFont, sans-serif</span>
              </div>
            </div>
            <div class="ds-font-card">
              <div class="ds-font-specimen ds-font-specimen--serif">
                Aa Bb Cc
              </div>
              <div class="ds-font-meta">
                <span class="ds-token-name">--font-serif</span>
                <span class="ds-font-name">Instrument Serif</span>
                <span class="ds-font-fallback">Times New Roman, Georgia, serif</span>
              </div>
            </div>
            <div class="ds-font-card">
              <div class="ds-font-specimen ds-font-specimen--body">
                Aa Bb Cc
              </div>
              <div class="ds-font-meta">
                <span class="ds-token-name">--font-body</span>
                <span class="ds-font-name">Roboto Flex</span>
                <span class="ds-font-fallback">-apple-system, BlinkMacSystemFont, sans-serif</span>
              </div>
            </div>
            <div class="ds-font-card">
              <div class="ds-font-specimen ds-font-specimen--mono">
                Aa Bb 01
              </div>
              <div class="ds-font-meta">
                <span class="ds-token-name">--font-mono</span>
                <span class="ds-font-name">JetBrains Mono</span>
                <span class="ds-font-fallback">SF Mono, Consolas, monospace</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Type Scale -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Type Scale</h3>
          <div class="ds-type-scale">
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-hero</code><em>72–144px</em></span>
              <span class="ds-type-sample ds-type-sample--hero">Hero</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-display</code><em>56–112px</em></span>
              <span class="ds-type-sample ds-type-sample--display">Display</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-6xl</code><em>64–128px</em></span>
              <span class="ds-type-sample ds-type-sample--6xl">6XL</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-5xl</code><em>48–88px</em></span>
              <span class="ds-type-sample ds-type-sample--5xl">5XL</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-4xl</code><em>40–64px</em></span>
              <span class="ds-type-sample ds-type-sample--4xl">4XL</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-3xl</code><em>32–48px</em></span>
              <span class="ds-type-sample ds-type-sample--3xl">3XL</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-2xl</code><em>24–32px</em></span>
              <span class="ds-type-sample ds-type-sample--2xl">2XL</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-xl</code><em>20–24px</em></span>
              <span class="ds-type-sample ds-type-sample--xl">XL</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-lg</code><em>17–18px</em></span>
              <span class="ds-type-sample ds-type-sample--lg">LG — The quick brown fox</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-base</code><em>15–16px</em></span>
              <span class="ds-type-sample ds-type-sample--base">Base — The quick brown fox jumps</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-sm</code><em>13–14px</em></span>
              <span class="ds-type-sample ds-type-sample--sm">SM — The quick brown fox jumps over the lazy dog</span>
            </div>
            <div class="ds-type-row">
              <span class="ds-type-label"><code>--text-xs</code><em>11–12px</em></span>
              <span class="ds-type-sample ds-type-sample--xs">XS — The quick brown fox jumps over the lazy dog and back again</span>
            </div>
          </div>
        </div>

        <!-- Heading Hierarchy -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Heading Hierarchy</h3>
          <div class="ds-heading-demo">
            <div class="ds-heading-row">
              <span class="ds-type-label"><code>h1</code><em>--text-5xl</em></span>
              <h1>Quality Time Design Agency</h1>
            </div>
            <div class="ds-heading-row">
              <span class="ds-type-label"><code>h2</code><em>--text-4xl</em></span>
              <h2>Crafting Design Systems</h2>
            </div>
            <div class="ds-heading-row">
              <span class="ds-type-label"><code>h3</code><em>--text-3xl</em></span>
              <h3>Editorial Contrast</h3>
            </div>
            <div class="ds-heading-row">
              <span class="ds-type-label"><code>h4</code><em>--text-2xl</em></span>
              <h4>Visual Identity</h4>
            </div>
            <div class="ds-heading-row">
              <span class="ds-type-label"><code>h5</code><em>--text-xl</em></span>
              <h5>Brand Strategy</h5>
            </div>
            <div class="ds-heading-row">
              <span class="ds-type-label"><code>h6</code><em>--text-lg</em></span>
              <h6>Design Tokens</h6>
            </div>
          </div>
        </div>

        <!-- Font Weights -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Font Weights</h3>
          <div class="ds-weight-grid">
            <div class="ds-weight-item">
              <span class="ds-weight-sample" style="font-weight: var(--font-light)">Light</span>
              <span class="ds-token-name">--font-light</span>
              <span class="ds-value">300</span>
            </div>
            <div class="ds-weight-item">
              <span class="ds-weight-sample" style="font-weight: var(--font-regular)">Regular</span>
              <span class="ds-token-name">--font-regular</span>
              <span class="ds-value">400</span>
            </div>
            <div class="ds-weight-item">
              <span class="ds-weight-sample" style="font-weight: var(--font-medium)">Medium</span>
              <span class="ds-token-name">--font-medium</span>
              <span class="ds-value">500</span>
            </div>
            <div class="ds-weight-item">
              <span class="ds-weight-sample" style="font-weight: var(--font-semibold)">Semibold</span>
              <span class="ds-token-name">--font-semibold</span>
              <span class="ds-value">600</span>
            </div>
            <div class="ds-weight-item">
              <span class="ds-weight-sample" style="font-weight: var(--font-bold)">Bold</span>
              <span class="ds-token-name">--font-bold</span>
              <span class="ds-value">700</span>
            </div>
          </div>
        </div>

        <!-- Line Heights & Letter Spacing -->
        <div class="ds-subsection ds-two-col">
          <!-- Line Heights -->
          <div>
            <h3 class="ds-subsection-title">Line Heights</h3>
            <div class="ds-table">
              <div class="ds-table-row ds-table-header">
                <span>Token</span><span>Value</span><span>Preview</span>
              </div>
              <div class="ds-table-row">
                <span><code>--leading-hero</code></span><span>0.92</span>
                <span class="ds-leading-preview" style="line-height: 0.92">Quality<br />Time</span>
              </div>
              <div class="ds-table-row">
                <span><code>--leading-tight</code></span><span>1.05</span>
                <span class="ds-leading-preview" style="line-height: 1.05">Quality<br />Time</span>
              </div>
              <div class="ds-table-row">
                <span><code>--leading-snug</code></span><span>1.2</span>
                <span class="ds-leading-preview" style="line-height: 1.2">Quality<br />Time</span>
              </div>
              <div class="ds-table-row">
                <span><code>--leading-normal</code></span><span>1.5</span>
                <span class="ds-leading-preview" style="line-height: 1.5">Quality<br />Time</span>
              </div>
              <div class="ds-table-row">
                <span><code>--leading-relaxed</code></span><span>1.65</span>
                <span class="ds-leading-preview" style="line-height: 1.65">Quality<br />Time</span>
              </div>
              <div class="ds-table-row">
                <span><code>--leading-loose</code></span><span>1.85</span>
                <span class="ds-leading-preview" style="line-height: 1.85">Quality<br />Time</span>
              </div>
            </div>
          </div>

          <!-- Letter Spacing -->
          <div>
            <h3 class="ds-subsection-title">Letter Spacing</h3>
            <div class="ds-table">
              <div class="ds-table-row ds-table-header">
                <span>Token</span><span>Value</span><span>Preview</span>
              </div>
              <div class="ds-table-row">
                <span><code>--tracking-tightest</code></span><span>-0.04em</span>
                <span class="ds-tracking-preview" style="letter-spacing: -0.04em">QUALITY</span>
              </div>
              <div class="ds-table-row">
                <span><code>--tracking-tighter</code></span><span>-0.02em</span>
                <span class="ds-tracking-preview" style="letter-spacing: -0.02em">QUALITY</span>
              </div>
              <div class="ds-table-row">
                <span><code>--tracking-tight</code></span><span>-0.01em</span>
                <span class="ds-tracking-preview" style="letter-spacing: -0.01em">QUALITY</span>
              </div>
              <div class="ds-table-row">
                <span><code>--tracking-normal</code></span><span>0</span>
                <span class="ds-tracking-preview" style="letter-spacing: 0">QUALITY</span>
              </div>
              <div class="ds-table-row">
                <span><code>--tracking-wide</code></span><span>0.02em</span>
                <span class="ds-tracking-preview" style="letter-spacing: 0.02em">QUALITY</span>
              </div>
              <div class="ds-table-row">
                <span><code>--tracking-wider</code></span><span>0.04em</span>
                <span class="ds-tracking-preview" style="letter-spacing: 0.04em">QUALITY</span>
              </div>
              <div class="ds-table-row">
                <span><code>--tracking-caps</code></span><span>0.12em</span>
                <span class="ds-tracking-preview" style="letter-spacing: 0.12em">QUALITY</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======================================================
         COLORS
         ====================================================== -->
    <section class="ds-section ds-section--alt" id="colors">
      <div class="ds-container">
        <h2 class="ds-section-title">Colors</h2>

        <!-- Base Palette -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Base Palette</h3>
          <div class="ds-swatch-grid">
            <div class="ds-swatch" style="--swatch-bg: var(--color-ink); --swatch-text: var(--color-paper);">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-ink</span>
                <span class="ds-value">#0f1a2a</span>
              </div>
            </div>
            <div class="ds-swatch" style="--swatch-bg: var(--color-paper); --swatch-text: var(--color-ink);">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-paper</span>
                <span class="ds-value">#f8f8f7</span>
              </div>
            </div>
            <div class="ds-swatch" style="--swatch-bg: var(--color-cream); --swatch-text: var(--color-ink);">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-cream</span>
                <span class="ds-value">#f0efed</span>
              </div>
            </div>
            <div class="ds-swatch" style="--swatch-bg: var(--color-stone); --swatch-text: var(--color-ink);">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-stone</span>
                <span class="ds-value">#e5e4e1</span>
              </div>
            </div>
            <div class="ds-swatch" style="--swatch-bg: var(--color-mid-black); --swatch-text: var(--color-paper);">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-mid-black</span>
                <span class="ds-value">#3d5a7a</span>
              </div>
            </div>
            <div class="ds-swatch" style="--swatch-bg: var(--color-mid-white); --swatch-text: var(--color-ink);">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-mid-white</span>
                <span class="ds-value">#d0d0c8</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Accent -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Accent</h3>
          <div class="ds-swatch-grid ds-swatch-grid--accent">
            <div class="ds-swatch" style="--swatch-bg: var(--color-accent-light); --swatch-text: #fff;">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-accent-light</span>
                <span class="ds-value">#EF4444</span>
              </div>
            </div>
            <div class="ds-swatch ds-swatch--feature" style="--swatch-bg: var(--color-accent); --swatch-text: #fff;">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-accent</span>
                <span class="ds-value">#DC2626</span>
              </div>
            </div>
            <div class="ds-swatch" style="--swatch-bg: var(--color-accent-dark); --swatch-text: #fff;">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-accent-dark</span>
                <span class="ds-value">#B91C1C</span>
              </div>
            </div>
            <div class="ds-swatch" style="--swatch-bg: var(--color-accent-muted); --swatch-text: #fff;">
              <div class="ds-swatch-block"></div>
              <div class="ds-swatch-info">
                <span class="ds-token-name">--color-accent-muted</span>
                <span class="ds-value">#991B1B</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Gray Scale -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Gray Scale</h3>
          <div class="ds-gray-scale">
            <div class="ds-gray-swatch" style="background: var(--color-gray-100);">
              <span>100</span><span>#f5f6f7</span>
            </div>
            <div class="ds-gray-swatch" style="background: var(--color-gray-200);">
              <span>200</span><span>#e6e9ec</span>
            </div>
            <div class="ds-gray-swatch" style="background: var(--color-gray-300);">
              <span>300</span><span>#d0d5db</span>
            </div>
            <div class="ds-gray-swatch" style="background: var(--color-gray-400);">
              <span>400</span><span>#9aa5b1</span>
            </div>
            <div class="ds-gray-swatch" style="background: var(--color-gray-500);">
              <span>500</span><span>#6b7a8a</span>
            </div>
            <div class="ds-gray-swatch ds-gray-swatch--light" style="background: var(--color-gray-600);">
              <span>600</span><span>#4a5a6a</span>
            </div>
            <div class="ds-gray-swatch ds-gray-swatch--light" style="background: var(--color-gray-700);">
              <span>700</span><span>#334455</span>
            </div>
            <div class="ds-gray-swatch ds-gray-swatch--light" style="background: var(--color-gray-800);">
              <span>800</span><span>#1f2d3d</span>
            </div>
            <div class="ds-gray-swatch ds-gray-swatch--light" style="background: var(--color-gray-900);">
              <span>900</span><span>#141e2a</span>
            </div>
          </div>
        </div>

        <!-- Semantic Colors -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Semantic Tokens</h3>
          <div class="ds-semantic-grid">
            <div class="ds-semantic-group">
              <h4 class="ds-semantic-group-label">Text</h4>
              <div class="ds-semantic-row">
                <span class="ds-semantic-swatch" style="color: var(--color-text-primary);">Aa</span>
                <span class="ds-token-name">--color-text-primary</span>
                <span class="ds-value">→ ink</span>
              </div>
              <div class="ds-semantic-row">
                <span class="ds-semantic-swatch" style="color: var(--color-text-secondary);">Aa</span>
                <span class="ds-token-name">--color-text-secondary</span>
                <span class="ds-value">→ gray-600</span>
              </div>
              <div class="ds-semantic-row">
                <span class="ds-semantic-swatch" style="color: var(--color-text-muted);">Aa</span>
                <span class="ds-token-name">--color-text-muted</span>
                <span class="ds-value">→ gray-500</span>
              </div>
              <div class="ds-semantic-row">
                <span class="ds-semantic-swatch ds-semantic-swatch--inverse">Aa</span>
                <span class="ds-token-name">--color-text-inverse</span>
                <span class="ds-value">→ paper</span>
              </div>
            </div>
            <div class="ds-semantic-group">
              <h4 class="ds-semantic-group-label">Background</h4>
              <div class="ds-semantic-row">
                <span class="ds-semantic-bg" style="background: var(--color-bg-primary);"></span>
                <span class="ds-token-name">--color-bg-primary</span>
                <span class="ds-value">→ paper</span>
              </div>
              <div class="ds-semantic-row">
                <span class="ds-semantic-bg" style="background: var(--color-bg-secondary);"></span>
                <span class="ds-token-name">--color-bg-secondary</span>
                <span class="ds-value">→ cream</span>
              </div>
              <div class="ds-semantic-row">
                <span class="ds-semantic-bg" style="background: var(--color-bg-tertiary);"></span>
                <span class="ds-token-name">--color-bg-tertiary</span>
                <span class="ds-value">→ stone</span>
              </div>
              <div class="ds-semantic-row">
                <span class="ds-semantic-bg" style="background: var(--color-bg-inverse);"></span>
                <span class="ds-token-name">--color-bg-inverse</span>
                <span class="ds-value">→ ink</span>
              </div>
            </div>
            <div class="ds-semantic-group">
              <h4 class="ds-semantic-group-label">Border</h4>
              <div class="ds-semantic-row">
                <span class="ds-semantic-border" style="border-color: var(--color-border);"></span>
                <span class="ds-token-name">--color-border</span>
                <span class="ds-value">→ gray-200</span>
              </div>
              <div class="ds-semantic-row">
                <span class="ds-semantic-border" style="border-color: var(--color-border-strong);"></span>
                <span class="ds-token-name">--color-border-strong</span>
                <span class="ds-value">→ gray-300</span>
              </div>
              <div class="ds-semantic-row">
                <span class="ds-semantic-border" style="border-color: var(--color-accent);"></span>
                <span class="ds-token-name">--color-focus</span>
                <span class="ds-value">→ accent</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Shadows -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Shadows</h3>
          <div class="ds-shadow-grid">
            <div class="ds-shadow-card" style="box-shadow: var(--shadow-sm);">
              <span class="ds-token-name">--shadow-sm</span>
              <span class="ds-value">0 1px 2px</span>
            </div>
            <div class="ds-shadow-card" style="box-shadow: var(--shadow-md);">
              <span class="ds-token-name">--shadow-md</span>
              <span class="ds-value">0 4px 12px</span>
            </div>
            <div class="ds-shadow-card" style="box-shadow: var(--shadow-lg);">
              <span class="ds-token-name">--shadow-lg</span>
              <span class="ds-value">0 12px 32px</span>
            </div>
            <div class="ds-shadow-card" style="box-shadow: var(--shadow-xl);">
              <span class="ds-token-name">--shadow-xl</span>
              <span class="ds-value">0 24px 64px</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ======================================================
         SPACING
         ====================================================== -->
    <section class="ds-section" id="spacing">
      <div class="ds-container">
        <h2 class="ds-section-title">Spacing</h2>

        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Space Scale</h3>
          <div class="ds-space-scale">
            {[
              { token: '--space-px', label: 'px', px: '1px' },
              { token: '--space-05', label: '0.5', px: '2px' },
              { token: '--space-1', label: '1', px: '4px' },
              { token: '--space-2', label: '2', px: '8px' },
              { token: '--space-3', label: '3', px: '12px' },
              { token: '--space-4', label: '4', px: '16px' },
              { token: '--space-5', label: '5', px: '20px' },
              { token: '--space-6', label: '6', px: '24px' },
              { token: '--space-8', label: '8', px: '32px' },
              { token: '--space-10', label: '10', px: '40px' },
              { token: '--space-12', label: '12', px: '48px' },
              { token: '--space-16', label: '16', px: '64px' },
              { token: '--space-20', label: '20', px: '80px' },
