              </div>
              <div class="ds-table-row">
                <span><code>--ease-spring-bounce</code></span>
                <span class="ds-value ds-value--mono">0.175, 0.885, 0.32, 1.275</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Live easing demos -->
        <div class="ds-subsection">
          <h3 class="ds-subsection-title">Easing Previews <span class="ds-hint">(hover to animate)</span></h3>
