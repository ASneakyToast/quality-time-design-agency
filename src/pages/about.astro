---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Capabilities from '@/components/global/Capabilities.astro';
---

<BaseLayout
  title="About | Quality Time"
  description="Quality Time is a San Francisco based design collective founded by MFA design peers from California College of the Arts."
>
  <article class="about">
    <!-- Hero -->
    <header class="about-hero">
      <div class="about-hero-content">
        <h1 class="about-title">
          Quality Time is an independent design studio and small press.
        </h1>
        <p class="about-intro">
          Founded by MFA design peers from California College of the Arts, our practice foregrounds
          experimentation in material, process, and research methods to create publications and art
          objects with artists in the Bay Area and beyond.
        </p>
      </div>
    </header>

    <!-- Capabilities -->
    <Capabilities ctaText="Request a proposal" ctaLink="/contact" />
  </article>
</BaseLayout>

<style>
  .about {
    padding-bottom: 0;
  }

  /* ==========================================================================
     Hero
     ========================================================================== */
  .about-hero {
    padding: var(--space-32) var(--gutter) var(--section-gap);
  }

  .about-hero-content {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .about-title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    max-width: var(--container-lg);
    font-weight: var(--font-regular);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-tighter);
    margin-bottom: var(--space-8);
  }

  .about-title em {
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .about-intro {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);

  }

  /* ==========================================================================
     Responsive
     ========================================================================== */
  @media (max-width: 768px) {
    .about-hero {
      padding-top: var(--space-24);
    }

    .about-title {
      font-size: var(--text-4xl);
    }

    .about-intro {
      font-size: var(--text-lg);
    }
  }
</style>
